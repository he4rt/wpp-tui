# ──────────────────────────────────────────────────────────────
# wpp-tui — variáveis de ambiente
# Copie para .env e ajuste os valores:  cp .env.example .env
# Os scripts `pnpm dev` / `pnpm start` carregam o .env automaticamente
# (node --env-file-if-exists=.env).
# ──────────────────────────────────────────────────────────────

# ── Coletor → Laravel (integration-whatsapp) ──
# No Modo TUI o coletor é OPCIONAL: só liga se WEBHOOK_URL **e**
# WHATSAPP_WEBHOOK_SECRET estiverem definidas.
# No Modo headless (--headless / HEADLESS=1) as DUAS são OBRIGATÓRIAS:
# se faltar qualquer uma, o processo loga FATAL e sai com código ≠ 0
# ANTES de conectar (fail-fast). Veja docs/adr/0002 e a seção "Modo headless"
# do README.
# URL COMPLETA do endpoint (inclui o path). O sender faz POST direto nela,
# 1 requisição por evento. Ex.: https://api.seu-dominio.com/api/webhooks/whatsapp
WEBHOOK_URL=http://localhost:8000/api/webhooks/whatsapp

# Segredo compartilhado usado para assinar o corpo (HMAC-SHA256 → header X-Signature).
# DEVE ser idêntico ao configurado no Laravel. Gere um novo com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WHATSAPP_WEBHOOK_SECRET=troque-por-um-segredo-forte

# ── Modo headless (serviço, sem TUI) ──
# Liga o modo headless sem precisar passar --headless na linha de comando.
# Aceita 1 / true / yes. Deixe vazio/ausente para rodar a TUI normalmente.
# (No deploy systemd a unit já define HEADLESS=1.)
HEADLESS=

# ── Logs ──
# Nível do log do app/coletor (component: whatsapp / collector / retention).
# Em dev use 'trace'; 'silent' desliga. Padrão: info.
LOG_LEVEL=info

# Nível do log do Baileys (component: baileys), separado do app.
# Costuma ser barulhento — mantenha em 'warn'. Padrão: warn.
BAILEYS_LOG_LEVEL=warn

# No headless os logs saem em JSON na stdout (ideal para journald/journalctl).
# LOG_PRETTY=1 troca para pino-pretty (legível no terminal, p/ debug local).
# Em produção deixe vazio/0.
LOG_PRETTY=

# Opcional. Se definido, os logs vão para ESTE arquivo em vez da stdout.
# No headless a stdout é o padrão — só defina se quiser um arquivo dedicado.
# (No Modo TUI o app continua usando wa-logs.txt via src/logger.ts.)
WA_LOG_FILE=

# ── Retenção (prod) ──
# Apaga logs/<evento>/<dia>.json além de N dias. 0 = mantém tudo (comportamento antigo).
# No headless, se ficar ausente/0, o boot emite um WARN sobre crescimento de disco.
LOG_RETENTION_DAYS=14

# Poda logs/message-store/ (1 arquivo/mensagem) além de N dias. 0 = mantém tudo.
# (Só relevante no Modo TUI: o headless não usa o message-store.)
MESSAGE_STORE_RETENTION_DAYS=3
